public class Solution extends GuessGame {
    public int guessNumber(int n) {
        
        // Try every number from 1 to n
        for (int i = 1; i <= n; i++) {
            int res = guess(i);
            
            if (res == 0) {
                return i; // found the number
            }
        }
        
        return -1; // should never happen
    }
}
