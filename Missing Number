class Solution {
    public int missingNumber(int[] nums) {
        int n = nums.length;
        
        // Sum of first n natural numbers from 0 to n
        int expectedSum = n * (n + 1) / 2;
        
        int actualSum = 0;
        for (int num : nums) {
            actualSum += num;
        }
        
        // Missing number
        return expectedSum - actualSum;
    }
}
