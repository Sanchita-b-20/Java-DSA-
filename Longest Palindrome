class Solution {
    public int longestPalindrome(String s) {
        int[] freq = new int[128]; // ASCII (covers A-Z, a-z)

        // Count frequency of each character
        for (char c : s.toCharArray()) {
            freq[c]++;
        }

        int length = 0;
        boolean hasOdd = false;

        for (int count : freq) {
            if (count % 2 == 0) {
                length += count; // use all even counts
            } else {
                length += count - 1; // use even part of odd count
                hasOdd = true;
            }
        }

        // Add one center character if any odd exists
        if (hasOdd) {
            length += 1;
        }

        return length;
    }
}
